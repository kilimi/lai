__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.lai/
.lai/**

# IDEs / local shell history
.vscode/
.idea/
*.swp
*.swo
*~
.bash_history
.config/

